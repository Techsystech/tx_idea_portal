<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_idea_tag_tree" model="ir.ui.view">
        <field name="name">idea.tag.list</field>
        <field name="model">idea.tag</field>
        <field name="arch" type="xml">
            <list string="Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="is_public"/>
                <field name="idea_count"/>
            </list>
        </field>
    </record>

    <record id="view_idea_tag_form" model="ir.ui.view">
        <field name="name">idea.tag.form</field>
        <field name="model">idea.tag</field>
        <field name="arch" type="xml">
            <form string="Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="is_public"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_idea_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">idea.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
